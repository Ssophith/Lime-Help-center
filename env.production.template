# Production Environment Variables Template
# Copy this file to .env.production on the server and fill in the values
# chmod 600 .env.production after creating

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://help.lime.mn
NEXT_PUBLIC_SITE_NAME=LIME тусламж
PORT=3010

# Database
# Format: postgresql://username:password@host:port/database
# Docker Compose maps port 5444:5432 (host:container)
# Using same credentials as docker-compose.yml
DATABASE_URL=postgresql://limekb:CHANGE_ME_DB_PASSWORD@localhost:5444/limekb

# Admin Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET_32_BYTES

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=lime-kb
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-your-account-id.r2.dev

# TinyMCE Editor
NEXT_PUBLIC_TINYMCE_API_KEY=your_tinymce_api_key

# AI Assistant (Groq — powers /api/ask endpoint and chat widget)
# Free tier, no card required. Get one at https://console.groq.com/keys
# If unset, the AI chat widget returns 503 and degrades gracefully.
GROQ_API_KEY=gsk_...

# Optional: Redis-backed rate-limit. Required only when scaling beyond
# one PM2 instance — without it, each fork keeps its own in-memory counters
# and the effective per-IP limit becomes (limit * instance count).
# Format: redis://host:port  or  rediss://user:pass@host:port (TLS)
# REDIS_URL=

# Email Configuration (for user invites)
# Option 1: AWS SES SMTP (Recommended - use this for AWS SES)
NODEMAILER_HOST=email-smtp.us-west-2.amazonaws.com
NODEMAILER_PORT=465
NODEMAILER_USER=your_aws_ses_smtp_username
NODEMAILER_PASS=your_aws_ses_smtp_password
NODEMAILER_FROM=noreply@onlime.mn

# Option 2: AWS SES SDK (Alternative)
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SES_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SES_FROM=noreply@onlime.mn

# Option 3: Regular SMTP (Fallback)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@onlime.mn
